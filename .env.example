# Scienthesis LitHub Service — example environment file.

APP_NAME=ScienthesisLitHub
DEBUG=false
HOST=0.0.0.0
PORT=8200

# PostgreSQL — dedicated DB; never share with Identity.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scienthesis_lithub

# Redis — paper-metadata cache + reconciliation locks.
REDIS_URL=redis://localhost:6379/3

# CORS — comma-separated origin list, JSON array, or "*".
# In production this should ONLY include the BFF origins, not browser origins,
# because the LitHub API is consumed by BFFs not by browsers directly.
CORS_ORIGINS=*

# Identity Service — JWKS URL for verifying user access tokens.
IDENTITY_BASE_URL=http://localhost:8100
IDENTITY_JWKS_URL=http://localhost:8100/.well-known/jwks.json
IDENTITY_JWT_ISSUER=scienthesis-identity
IDENTITY_JWT_AUDIENCE=lithub

# Service-to-service auth — HS256 shared secret used to validate inbound
# X-Service-Token headers on /api/v1/internal/* endpoints.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SERVICE_TOKEN_SECRET=
SERVICE_TOKEN_ALLOWED_ISSUERS=litpulse,litportal,identity

# Outbound — needed for paper metadata enrichment (PubMed, CrossRef).
# Optional; when unset, papers are stored with only the metadata the caller
# supplied (DOI-only path).
NCBI_API_KEY=
NCBI_CONTACT_EMAIL=info@scienthesis.ai
